# medagent 环境变量配置模板
# 复制为 .env 并按需填写，.env 不会被 git 跟踪。
#
# 用法：
#   1. cp .env.example .env
#   2. 编辑 .env 填入实际值
#   3. 直接运行 go run ./cmd/server 等（会自动加载 .env）

# ---- LLM Provider 配置 ----
# provider: deepseek | qwen | openai
MEDAGENT_PROVIDER=deepseek

# 模型名（取决于 provider）
MEDAGENT_MODEL=deepseek-chat

# API Key（按 provider 选填对应的一个即可）
DEEPSEEK_API_KEY=sk-your-deepseek-key
# OPENAI_API_KEY=sk-your-openai-key
# DASHSCOPE_API_KEY=sk-your-qwen-key

# 自定义 API 端点（任意 OpenAI 兼容 API；设此项后忽略 MEDAGENT_PROVIDER）
# MEDAGENT_BASE_URL=https://your-proxy.example.com/v1

# ---- 服务配置 ----
# HTTP 监听地址（仅 cmd/server）
# MEDAGENT_ADDR=:8080

# 单次 LLM 调用超时（Go duration 格式，如 30s、1m）
# MEDAGENT_TIMEOUT=30s

# 会话无活动超时（Go duration 格式，如 30m、1h）
# MEDAGENT_SESSION_TTL=30m

# 关闭急症守护（设 1 关闭，默认开启）
# MEDAGENT_DISABLE_GUARDIAN=1

# ---- 日志配置 ----
# 诊疗日志目录（空字符串则不写日志）
# MEDAGENT_LOG_DIR=./logs

# ---- 真实验证测试（agent/realrun_test.go）----
# 启用真实验证（设 1 启用，默认跳过）
# MEDAGENT_REAL_LLM=1

# 真实验证用的 provider（默认 openai）
# MEDAGENT_LLM_PROVIDER=deepseek

# 真实验证用的 model（默认 gpt-4o-mini）
# MEDAGENT_LLM_MODEL=deepseek-chat

# 真实验证用的自定义 base URL
# MEDAGENT_LLM_BASE_URL=
